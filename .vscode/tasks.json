{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Full Dev Environment",
      "type": "shell",
      "command": "FRONTEND_API_MODE=local BACKEND_DB_MODE=dev ./scripts/start_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Workspace: FE Local API + BE Dev DB",
      "type": "shell",
      "command": "FRONTEND_API_MODE=local BACKEND_DB_MODE=dev ./scripts/start_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Workspace: FE Local API + BE Prod DB",
      "type": "shell",
      "command": "FRONTEND_API_MODE=local BACKEND_DB_MODE=prod ./scripts/start_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Workspace: FE Prod API + BE Dev DB",
      "type": "shell",
      "command": "FRONTEND_API_MODE=prod BACKEND_DB_MODE=dev ./scripts/start_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Workspace: FE Prod API + BE Prod DB",
      "type": "shell",
      "command": "FRONTEND_API_MODE=prod BACKEND_DB_MODE=prod ./scripts/start_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Workspace: Show Active Modes",
      "type": "shell",
      "command": "if [ -f ./.logs/active-mode.txt ]; then cat ./.logs/active-mode.txt; else echo \"No active mode file yet. Run a Workspace task first.\"; fi",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Open pgAdmin UI",
      "type": "shell",
      "command": "OPEN_PGADMIN_UI=1 ./scripts/start_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Stop Full Dev Environment",
      "type": "shell",
      "command": "./scripts/stop_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy Web to GitHub Pages",
      "type": "shell",
      "command": "./deploy_web.sh",
      "options": {
        "cwd": "${workspaceFolder}/../BB_flutter"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "One-Time: Replace Production main with Current Branch",
      "type": "shell",
      "command": "./scripts/deploy_server.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Merge Current Server Branch into main and Start New Branch",
      "type": "shell",
      "command": "./scripts/merge_server_branch_to_main.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Refresh Dev DB From Prod",
      "type": "shell",
      "command": "./scripts/refresh_dev_db_from_prod.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
