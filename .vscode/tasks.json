{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Full Dev Environment",
      "type": "shell",
      "command": "./scripts/start_full_dev_environment.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy Web to GitHub Pages",
      "type": "shell",
      "command": "./deploy_web.sh",
      "options": {
        "cwd": "${workspaceFolder}/../BB_flutter"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
